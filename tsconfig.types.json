{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "src",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/js/mnemonic.js",
    "src/js/cnutils.js"
  ],
  "exclude": [
    "src/wasm"
  ]
}
