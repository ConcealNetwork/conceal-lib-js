{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "src",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/js/mnemonic.js",
    "src/js/cnutils.js",
    "src/js/random.js",
    "src/js/cn.js",
    "src/js/transactions.js",
    "src/js/base58.js",
    "src/js/address.js",
    "src/js/tiers/secretbox.js"
  ],
  "exclude": [
    "src/wasm",
    "src/**/*.d.ts"
  ]
}
